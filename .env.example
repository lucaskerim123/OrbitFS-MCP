# --- Required to boot at all ---

# Absolute path to the shared FireStorm file root this server exposes.
# Windows path, backslashes are fine. The folder must exist before you
# start the server (deploy/Install-OrbitFS.ps1 in the orbitfs-panel
# repo creates the standard skeleton for you, at whatever location you choose).
HIVE_ROOT=C:\Project FireStorm\The Master Hive

# Bearer token clients (the webpanel, and any MCP client not going through
# Cloudflare Access OAuth) send as `Authorization: Bearer <this>`.
# Generate a random 40+ char value, e.g. in PowerShell:
#   -join ((48..57)+(97..122)|Get-Random -Count 40|%{[char]$_})
HIVE_API_KEY=

# Port this server listens on.
PORT=3939

# Public URL this server is reachable at (through the Cloudflare tunnel /
# reverse proxy). Used for OAuth discovery + issuer claims. Must match
# what Claude/ChatGPT connect to.
PUBLIC_BASE_URL=https://your-tunnel-domain.example.com

# Signs session/OAuth tokens. Generate a random 40+ char value the same
# way as HIVE_API_KEY above. Changing this invalidates existing sessions.
SESSION_SECRET=

# --- Optional: Cloudflare Access OAuth ---
# Only needed if Claude/ChatGPT connect via OAuth through Cloudflare
# Access instead of the HIVE_API_KEY bearer-token fallback. Leave blank
# to skip OAuth entirely and use HIVE_API_KEY for every client (including
# the webpanel) - see the Auth model section in CLAUDE.md.
# These four come from a Cloudflare Access "SaaS application" (OIDC) you
# create yourself in the Zero Trust dashboard - step-by-step walkthrough
# in orbitfs-panel/GETTING_STARTED.md, section "Cloudflare Access (OIDC)".
# The redirect URL you register there MUST be exactly:
#   <PUBLIC_BASE_URL>/oauth/cf-callback
CF_AUTHORIZE_URL=
CF_TOKEN_URL=
CF_CLIENT_ID=
CF_CLIENT_SECRET=

# --- Optional: trash retention ---
# Max upload size in megabytes for upload_file, fetch_url_to_file, and /api/upload.
# Defaults to 100 if unset.
UPLOAD_MAX_MB=100

# Days before items in Trash are auto-purged. Defaults to 4 if unset.
TRASH_RETENTION_DAYS=4

