HIVE_API_KEY=
HIVE_ROOT=
PORT=
CF_CLIENT_ID=
CF_CLIENT_SECRET=
CF_AUTHORIZE_URL=
CF_TOKEN_URL=
SESSION_SECRET=
UPLOAD_MAX_MB=
PUBLIC_BASE_URL=
ORBITFS_WIDGET_DOMAIN=
# MCP client access grants (see orbitfs-panel CLAUDE.md / workspace-mcp.js).
# MCP_INTERNAL_KEY must match orbitfs-panel's .env exactly. Leave unset to
# keep legacy behavior (every authenticated connection is unrestricted).
PANEL_INTERNAL_URL=http://127.0.0.1:4000
MCP_INTERNAL_KEY=

ORBITFS_LICENSE_ENFORCE=false
ORBITFS_LICENSE_API_URL=
ORBITFS_LICENSE_VALIDATE_PATH=/api/license/validate
ORBITFS_LICENSE_DIR=C:\ProgramData\OrbitFS
ORBITFS_LICENSE_REFRESH_MINUTES=5
ORBITFS_LICENSE_GRACE_HOURS=72
ORBITFS_LICENSE_TIMEOUT_MS=8000